// Singularity is always on — the execution environment only has Nextflow.
// Set NXF_SINGULARITY_CACHEDIR in your environment to share pulled images
// across runs (strongly recommended on shared HPC storage).
singularity {
    enabled    = true
    autoMounts = true
}

params {
    // Required
    input         = null
    plsdb_sketch  = null

    // Output
    outdir        = 'results'
    help          = false

    // Mash screen
    mash_min_identity = 0.90
    mash_max_pvalue   = 1e-5
    mash_threads      = 4

    // fastp
    fastp_min_length  = 50
    fastp_threads     = 4

    // Optional BWA mapping
    run_mapping       = false
    plsdb_fasta       = null
    bwa_threads       = 4
    min_coverage_pct  = 50.0   // % of plasmid length covered
    min_mean_depth    = 1.0
}

process {
    withLabel: 'process_single' {
        cpus   = 1
        memory = '2 GB'
        time   = '1 h'
    }
    withLabel: 'process_medium' {
        cpus   = 4
        memory = '8 GB'
        time   = '4 h'
    }
    withLabel: 'process_high' {
        cpus   = 8
        memory = '16 GB'
        time   = '8 h'
    }
}

profiles {
    conda {
        conda.enabled    = true
        conda.useMamba   = false
    }

    mamba {
        conda.enabled    = true
        conda.useMamba   = true
    }

    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    test {
        params.input        = "${projectDir}/assets/test_samplesheet.csv"
        params.plsdb_sketch = "${projectDir}/test_data/plsdb_test.msh"
    }

    // Slurm scheduler — combine with default Singularity support above
    slurm {
        process.executor = 'slurm'
        process {
            withLabel: 'process_single' {
                clusterOptions = '--ntasks=1 --cpus-per-task=1'
            }
            withLabel: 'process_medium' {
                clusterOptions = '--ntasks=1 --cpus-per-task=4'
            }
            withLabel: 'process_high' {
                clusterOptions = '--ntasks=1 --cpus-per-task=8'
            }
        }
    }
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
}

manifest {
    name        = 'plsdb-search'
    description = 'Plasmid detection from Illumina reads using PLSDB2025'
    version     = '1.0.0'
    nextflowVersion = '>=23.04'
}
